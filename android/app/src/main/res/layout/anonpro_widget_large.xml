<?xml version="1.0" encoding="utf-8"?>
<!--
  VisionOS-Inspired Large Widget
  Layout: 4x4 — Header | Confession Card | 3 Stats | Quick Dock
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- ── Header ──────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <!-- Gradient avatar -->
        <FrameLayout
            android:id="@+id/btn_profile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_avatar_bg">
            <TextView
                android:id="@+id/tv_profile_initial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AnonPro"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Updated: "
                    android:textColor="#44FFFFFF"
                    android:textSize="9sp" />
                <TextView
                    android:id="@+id/tv_last_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Just now"
                    android:textColor="#66FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Reload button -->
        <LinearLayout
            android:id="@+id/btn_reload"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↺ "
                android:textColor="#5599FF"
                android:textSize="14sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sync"
                android:textColor="#5599FF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Divider ──────────────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#20FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- ── Latest Confession Card ─────────────────── -->
    <LinearLayout
        android:id="@+id/card_latest_anon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:background="@drawable/widget_inner_box"
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤫 "
                android:textSize="13sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LATEST CONFESSION"
                android:textColor="#8866FF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_latest_anon_preview"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Loading..."
            android:textColor="#EEFFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:maxLines="5"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- ── Stats Row (3 cards) ──────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginBottom="10dp">

        <!-- Posts -->
        <LinearLayout
            android:id="@+id/btn_home"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="✦"
                android:textColor="#0099FF"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tv_stat_posts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#0099FF"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Posts"
                android:textColor="#AAFFFFFF"
                android:textSize="9sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="last 24h"
                android:textColor="#44FFFFFF"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Anon -->
        <LinearLayout
            android:id="@+id/btn_anon"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <TextView
                android:text="◎"
                android:textColor="#8844FF"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tv_stat_anon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#8844FF"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anon Posts"
                android:textColor="#AAFFFFFF"
                android:textSize="9sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="confessions"
                android:textColor="#44FFFFFF"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Messages -->
        <LinearLayout
            android:id="@+id/btn_inbox"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:text="✉"
                android:textColor="#33E88A"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:id="@+id/tv_stat_inbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#33E88A"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textColor="#AAFFFFFF"
                android:textSize="9sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unread"
                android:textColor="#44FFFFFF"
                android:textSize="7sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Quick-Dock Row ────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:orientation="horizontal"
        android:weightSum="4">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/dock_home"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⌂"
                android:textColor="#0099FF"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#66FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Anonymous -->
        <LinearLayout
            android:id="@+id/dock_anon"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◉"
                android:textColor="#8844FF"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anon"
                android:textColor="#66FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Inbox -->
        <LinearLayout
            android:id="@+id/dock_inbox"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="5dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✉"
                android:textColor="#33E88A"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inbox"
                android:textColor="#66FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/dock_profile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:background="@drawable/widget_inner_box"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◑"
                android:textColor="#FFAA22"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#66FFFFFF"
                android:textSize="8sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
